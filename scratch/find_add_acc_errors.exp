expect "password:"
send "e+6XDV^uLDJSQj\r"
expect "#"
send "grep -i 'error\\|ошибка\\|код\\|code\\|sign_in\\|password\\|Ошибка' /root/.pm2/logs/bot-logistic-out.log | tail -30\r"
